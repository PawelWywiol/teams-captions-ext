{
  "name": "teams-captions-ext",
  "version": "0.1.0",
  "private": true,
  "description": "Safari-first Teams captions extension starter",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:extension": "node ./scripts/build-extension.mjs",
    "dev:mock-proxy": "node ./scripts/mock-llm-proxy.mjs",
    "package:chromium": "node ./scripts/package-chromium.mjs",
    "package:safari": "node ./scripts/package-safari.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "format": "oxfmt \"src/**/*.ts\" \"src/**/*.tsx\" \"tests/**/*.ts\" \"tests/**/*.tsx\" package.json src/manifest.json",
    "format:check": "oxfmt --check \"src/**/*.ts\" \"src/**/*.tsx\" \"tests/**/*.ts\" \"tests/**/*.tsx\" package.json src/manifest.json",
    "audit:deps": "audit-ci --config ./audit-ci.json",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@preact/signals": "^2.9.0",
    "dexie": "^4.4.2",
    "preact": "^10.29.2"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/preact": "^3.2.4",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^25.9.1",
    "audit-ci": "^7.1.0",
    "esbuild": "^0.28.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.8",
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "packageManager": "pnpm@11.1.3"
}
