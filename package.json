{
  "name": "teams-captions-ext",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Safari-first Teams captions extension starter",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "oxlint .",
    "audit:deps": "audit-ci --moderate",
    "prepare": "lefthook install"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "audit-ci": "^7.1.0",
    "lefthook": "^1.11.2",
    "oxlint": "^0.15.14",
    "typescript": "^5.8.2",
    "vitest": "^2.1.9"
  }
}
